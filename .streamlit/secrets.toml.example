# Copy to .streamlit/secrets.toml (gitignored) or paste into
# Streamlit Cloud -> Manage app -> Settings -> Secrets.
#
# Every entry is OPTIONAL. With none of them the app runs in Demo Mode.

# --- App ---------------------------------------------------------------------
# APP_PASSWORD  = "change-me"        # omit to use the demo key `cldfinops`
# ORGANISATION  = "Con Edison"
# FINOPS_MODE   = "demo"             # "demo" | "live"

# --- AI Copilot (OpenAI + LangGraph) -----------------------------------------
# Without OPENAI_API_KEY the Copilot tab explains what it would have done
# rather than failing.
# OPENAI_API_KEY    = "sk-..."
# OPENAI_MODEL      = "gpt-5"        # specialists
# OPENAI_MODEL_FAST = "gpt-5-mini"   # supervisor routing (small-model-first)

# --- Durable state -----------------------------------------------------------
# Scenarios, allocation policies and budget overrides. Without this we fall back
# to SQLite, which Streamlit Cloud wipes on every reboot.
# DATABASE_URL = "postgresql://user:pass@host/db"

# =============================================================================
# LIVE MODE CONNECTORS
# Set FINOPS_MODE = "live" and configure the clouds you actually use.
# Uncomment the matching SDK at the bottom of requirements.txt.
#
# HOW MANY CREDENTIALS DO YOU ACTUALLY NEED?
#
# Far fewer than you think. One credential already spans many accounts, because
# that is how each provider aggregates billing:
#
#   AWS    Cost Explorer / Data Exports at the PAYER (management) account return
#          every linked account. They arrive in FOCUS as `SubAccountId`.
#          One payer = one credential, however many member accounts it has.
#   Azure  Billing-account scope covers every subscription beneath it.
#          Subscription scope covers exactly one -- prefer the billing account.
#   GCP    A billing account's BigQuery export carries every project it pays
#          for. They arrive as `SubAccountId`.
#
# So the single-payer block below is enough for most estates.
#
# You need a SECOND credential only for a second PAYER: another AWS
# organization, another Azure tenant or billing account, another GCP billing
# account. A regulated utility usually has several, because the regulated and
# unregulated entities cannot share a bill. Declare each one as an [[accounts]]
# entry; they are pulled in parallel and concatenated into one FOCUS frame,
# where `BillingAccountId` keeps them apart.
# =============================================================================

# --- Multiple payers / tenants / billing accounts ----------------------------
# Supersedes the single-payer blocks below when present.
#
# [[accounts]]
# cloud     = "AWS"
# name      = "ConEd Regulated payer"
# connector = "aws_native"
# [accounts.secrets]
# AWS_ACCESS_KEY_ID     = "..."
# AWS_SECRET_ACCESS_KEY = "..."
#
# [[accounts]]
# cloud     = "AWS"
# name      = "ConEd Clean Energy payer"
# connector = "aws_native"
# [accounts.secrets]
# AWS_ACCESS_KEY_ID     = "..."
# AWS_SECRET_ACCESS_KEY = "..."
#
# [[accounts]]
# cloud     = "Azure"
# name      = "Enterprise Agreement"
# connector = "azure_native"
# [accounts.options]
# scope = "providers/Microsoft.Billing/billingAccounts/1234567"
# [accounts.secrets]
# AZURE_TENANT_ID     = "..."
# AZURE_CLIENT_ID     = "..."
# AZURE_CLIENT_SECRET = "..."
#
# [[accounts]]
# cloud     = "GCP"
# name      = "Billing account 01A2B3"
# connector = "gcp_native"
# [accounts.secrets]
# GCP_BILLING_ACCOUNT_ID = "01A2B3-C4D5E6-F70819"
#
# A binding may also point at a procured tool instead of a cloud:
# [[accounts]]
# cloud     = "AWS"
# name      = "Cloudability (all clouds)"
# connector = "cloudability"

# --- AWS ---------------------------------------------------------------------
# Omit the keys entirely to use the default credential chain (instance role,
# SSO, ~/.aws/credentials).
# AWS_ACCESS_KEY_ID     = "..."
# AWS_SECRET_ACCESS_KEY = "..."
# AWS_SESSION_TOKEN     = "..."
# AWS_REGION            = "us-east-1"
# Preferred: a FOCUS 1.2 Data Export in S3. Gives a real ListCost, so Effective
# Savings Rate is correct. Cost Explorer cannot provide list price.
# AWS_FOCUS_S3_URI      = "s3://coned-finops-exports/focus/"

# --- Azure -------------------------------------------------------------------
# AZURE_TENANT_ID         = "..."
# AZURE_CLIENT_ID         = "..."
# AZURE_CLIENT_SECRET     = "..."
# AZURE_SUBSCRIPTION_ID   = "..."
# AZURE_BILLING_ACCOUNT_ID = "..."   # billing-account scope instead of subscription

# --- GCP ---------------------------------------------------------------------
# GCP_SERVICE_ACCOUNT_JSON = '{"type":"service_account","project_id":"..."}'
# GCP_PROJECT_ID           = "coned-finops"
# GCP_BILLING_ACCOUNT_ID   = "01A2B3-C4D5E6-F70819"
# GCP_BQ_DATASET           = "billing_export"
# GCP_FOCUS_TABLE          = "gcp_billing_export_focus_01A2B3_C4D5E6_F70819"

# =============================================================================
# PROCURED FINOPS PLATFORM (pick whichever the client buys)
# =============================================================================

# --- Apptio Cloudability (IBM) ----------------------------------------------
# CLOUDABILITY_API_KEY        = "..."
# CLOUDABILITY_HOST           = "api.cloudability.com"   # or api-eu / api-au / api.usgov ...
# CLOUDABILITY_OPENTOKEN      = "..."   # Frontdoor auth; required for GovCloud
# CLOUDABILITY_ENVIRONMENT_ID = "..."

# --- Tanzu CloudHealth (Broadcom) -------------------------------------------
# CLOUDHEALTH_API_KEY = "..."
# CLOUDHEALTH_ORG_ID  = "..."

# --- Flexera One -------------------------------------------------------------
# FLEXERA_REFRESH_TOKEN = "..."        # or FLEXERA_CLIENT_ID + FLEXERA_CLIENT_SECRET
# FLEXERA_ORG_ID        = "..."
# FLEXERA_ZONE          = "com"        # com | eu | au

# --- Finout ------------------------------------------------------------------
# FINOUT_CLIENT_ID  = "..."
# FINOUT_SECRET_KEY = "..."

# --- Vantage -----------------------------------------------------------------
# VANTAGE_API_TOKEN = "..."

# --- CloudZero ---------------------------------------------------------------
# Note: 60 cost requests per DAY. The connector caches aggressively.
# CLOUDZERO_API_KEY = "..."

# --- Harness CCM -------------------------------------------------------------
# HARNESS_API_KEY    = "..."
# HARNESS_ACCOUNT_ID = "..."

# --- nOps --------------------------------------------------------------------
# NOPS_API_KEY = "..."

# --- Kubernetes allocation ---------------------------------------------------
# KUBECOST_URL = "http://kubecost-cost-analyzer.kubecost:9090"
# OPENCOST_URL = "http://opencost.opencost:9003"

# --- IBM Turbonomic (recommendations only, not a billing source) -------------
# TURBONOMIC_HOST     = "turbo.example.com"
# TURBONOMIC_USERNAME = "..."
# TURBONOMIC_PASSWORD = "..."

# --- ServiceNow Cloud Cost Management ----------------------------------------
# The CCM cost table name is not publicly documented -- enumerate it in your own
# instance before setting SERVICENOW_COST_TABLE.
# SERVICENOW_INSTANCE   = "coned"
# SERVICENOW_USERNAME   = "..."
# SERVICENOW_PASSWORD   = "..."
# SERVICENOW_COST_TABLE = "sn_ccm_cost_line_item"
